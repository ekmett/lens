// Hierarchy.dot — source of truth for images/Hierarchy.png (the lens "field guide").
//
// This Graphviz file replaces the old creately.com diagram, whose source was lost
// (see the project history around issues #828 / #1012). Regenerate the raster with:
//
//     scripts/hierarchy            # needs `dot` from graphviz (brew install graphviz)
//
// Layout follows the optic lattice: an optic can be used as any type linked ABOVE
// it, so the hollow UML arrows point up — from each optic to the weaker ones it can
// stand in for. The MOST CAPABLE optic, Equality (usable as every other), sits at
// the BOTTOM. The maximal (most specialised) optics — Fold, Setter and Review —
// can't be used as anything further; note Getter is NOT maximal, since every Getter
// is also a Fold (Getter -> Fold).
//
// Each box is one node whose label is an HTML-like <TABLE>:
//   row 1  — the optic and its type parameters (e.g. "Lens s t a b")
//   row 2  — the *type synonym* it expands to (kept verbatim from Control.Lens.Type)
//   rows 3+ — a few headline combinators, one <TR> per line.
// To add detail later, just add more <TR> rows; nothing else needs to change.
// Inside HTML labels, write ">" as "&gt;" (so "->" is "-&gt;", "=>" is "=&gt;").

digraph LensHierarchy {
  rankdir=BT;
  bgcolor="white";
  node [shape=plaintext, fontname="Helvetica", fontsize=10];
  edge [color="#36486b", arrowhead=onormal, arrowsize=1.1, penwidth=1.0];

  // ---------------------------------------------------------------- Equality
  Equality [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Equality s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall p f. p a (f b) -&gt; p s (f t)</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">simple :: Equality' a a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">mapEq :: Equality s t a b -&gt; f s -&gt; f a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">fromEq :: Equality s t a b -&gt; Equality b a t s</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">substEq :: Equality s t a b -&gt; ((s ~ a, t ~ b) =&gt; r) -&gt; r</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Iso
  Iso [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Iso s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall p f. (Profunctor p, Functor f) =&gt; p a (f b) -&gt; p s (f t)</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">iso :: (s -&gt; a) -&gt; (b -&gt; t) -&gt; Iso s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">from :: Iso s t a b -&gt; Iso b a t s</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">enum :: Enum a =&gt; Iso' Int a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">mapping :: Functor f =&gt; Iso s t a b -&gt; Iso (f s) (f t) (f a) (f b)</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">curried :: Iso ((a, b) -&gt; c) ((d, e) -&gt; f) (a -&gt; b -&gt; c) (d -&gt; e -&gt; f)</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">au :: Iso s t a b -&gt; ((b -&gt; t) -&gt; e -&gt; s) -&gt; e -&gt; a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">under :: Iso s t a b -&gt; (t -&gt; s) -&gt; b -&gt; a</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Lens
  Lens [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Lens s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall f. Functor f =&gt; (a -&gt; f b) -&gt; s -&gt; f t</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">lens :: (s -&gt; a) -&gt; (s -&gt; b -&gt; t) -&gt; Lens s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">_1 :: Field1 s t a b =&gt; Lens s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">..</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">_9 :: Field9 s t a b =&gt; Lens s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">inside :: Lens s t a b -&gt; Lens (e -&gt; s) (e -&gt; t) (e -&gt; a) (e -&gt; b)</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">outside :: Prism s t a b -&gt; Lens (t -&gt; r) (s -&gt; r) (b -&gt; r) (a -&gt; r)</TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(%%~) :: Functor f =&gt; Lens s t a b -&gt; (a -&gt; f b) -&gt; s -&gt; f t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(%%=) :: MonadState s m =&gt; Lens s s a b -&gt; (a -&gt; (r, b)) -&gt; m r</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Prism
  Prism [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Prism s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall p f. (Choice p, Applicative f) =&gt; p a (f b) -&gt; p s (f t)</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">prism :: (b -&gt; t) -&gt; (s -&gt; Either t a) -&gt; Prism s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">_Left :: Prism (Either a c) (Either b c) a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">_Right :: Prism (Either c a) (Either c b) a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">...</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Getter
  Getter [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Getter s a</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall f. (Contravariant f, Functor f) =&gt; (a -&gt; f a) -&gt; s -&gt; f s</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">to :: (s -&gt; a) -&gt; Getter s a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">view :: MonadReader s m =&gt; Getter s a -&gt; m a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">use :: MonadState s m =&gt; Getter s a -&gt; m a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(^.) :: s -&gt; Getter s a -&gt; a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">foldMapOf :: Getter s a -&gt; (a -&gt; r) -&gt; s -&gt; r</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Traversal
  Traversal [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Traversal s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall f. Applicative f =&gt; (a -&gt; f b) -&gt; s -&gt; f t</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">traverse :: Traversable f =&gt; Traversal (f a) (f b) a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">mapMOf :: Monad m =&gt; Traversal s t a b -&gt; (a -&gt; m b) -&gt; s -&gt; m t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">mapAccumLOf :: Traversal s t a b -&gt; (acc -&gt; a -&gt; (acc, b)) -&gt; acc -&gt; s -&gt; (acc, t)</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">transposeOf :: Traversal s t [a] a -&gt; s -&gt; [t]</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">elementOf :: Traversal' s a -&gt; Int -&gt; IndexedTraversal' Int s a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">...</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(%%~) :: Applicative f =&gt; Traversal s t a b -&gt; (a -&gt; f b) -&gt; s -&gt; f t</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Setter
  Setter [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Setter s t a b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall f. Settable f =&gt; (a -&gt; f b) -&gt; s -&gt; f t</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">sets :: ((a -&gt; b) -&gt; s -&gt; t) -&gt; Setter s t a b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">mapped :: Functor f =&gt; Setter (f a) (f b) a b</TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">over, (%~) :: Setter s t a b -&gt; (a -&gt; b) -&gt; s -&gt; t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">set, (.~) :: Setter s t a b -&gt; b -&gt; s -&gt; t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(+~) :: Num a =&gt; Setter s t a a -&gt; a -&gt; s -&gt; t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(%=) :: MonadState s m =&gt; Setter s s a b -&gt; (a -&gt; b) -&gt; m ()</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(.=) :: MonadState s m =&gt; Setter s s a b -&gt; b -&gt; m ()</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">...</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Fold
  Fold [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Fold s a</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall f. (Contravariant f, Applicative f) =&gt; (a -&gt; f a) -&gt; s -&gt; f s</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">folded :: Foldable f =&gt; IndexedFold Int (f a) a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">foldMapOf :: Monoid r =&gt; Fold s a -&gt; (a -&gt; r) -&gt; s -&gt; r</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">foldrOf :: Fold s a -&gt; (a -&gt; r -&gt; r) -&gt; r -&gt; s -&gt; r</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">toListOf :: Fold s a -&gt; s -&gt; [a]</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">anyOf :: Fold s a -&gt; (a -&gt; Bool) -&gt; s -&gt; Bool</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(^..) :: s -&gt; Fold s a -&gt; [a]</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">(^?) :: s -&gt; Fold s a -&gt; Maybe a</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">...</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- Review  (#828: was 4-param "Review s a"; correct type is "Review t b")
  Review [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3" COLOR="#36486b" BGCOLOR="#eef3fa">
      <TR><TD ALIGN="CENTER" BGCOLOR="#dde6f2"><B>Review t b</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT"><I>forall p f. (Choice p, Bifunctor p, Settable f) =&gt; Optic' p f t b</I></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">unto :: (b -&gt; t) -&gt; Review t b</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">re :: Review t b -&gt; Getter b t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">review :: MonadReader b m =&gt; Review t b -&gt; m t</TD></TR>
      <TR><TD ALIGN="LEFT" BALIGN="LEFT">reuse :: MonadState b m =&gt; Review t b -&gt; m t</TD></TR>
    </TABLE>>];

  // ---------------------------------------------------------------- generalization lattice (subtype -> supertype; rankdir=BT draws it upward)
  Equality  -> Iso;
  Iso       -> Lens;
  Iso       -> Prism;
  Lens      -> Getter    [label="s = t\na = b"];
  Lens      -> Traversal;
  Prism     -> Traversal;
  Prism     -> Review    [label="s = t\na = b"];
  Traversal -> Setter;
  Traversal -> Fold      [label="s = t\na = b"];
  Getter    -> Fold;

  // keep the tiers visually aligned (Equality bottom ... Fold/Setter top)
  { rank=same; Lens; Prism; }
  { rank=same; Getter; Traversal; Review; }
  { rank=same; Fold; Setter; }
}
